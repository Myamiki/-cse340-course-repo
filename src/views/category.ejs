<%- include('partials/header') %>

<main>
  <a href="/categories" class="back-link">&larr; Back to Categories</a>

  <h1><%= category.name %></h1>
  <p style="color:var(--muted);margin-bottom:32px;">Service projects in this category.</p>

  <% if (!projects || projects.length === 0) { %>
    <p style="color:var(--muted);text-align:center;padding:60px 0;">No projects in this category yet.</p>
  <% } else { %>
    <ul class="card-grid">
      <% projects.forEach(project => { %>
        <li class="card">
          <div class="card-body">
            <h3><a href="/project/<%= project.project_id %>"><%= project.title %></a></h3>
            <div class="card-meta">
              <span class="card-meta-item">&#127970; <%= project.organization_name %></span>
            </div>
          </div>
          <div class="card-footer">
            <a href="/project/<%= project.project_id %>" class="btn btn-sm">View details</a>
          </div>
        </li>
      <% }); %>
    </ul>
  <% } %>
</main>

<%- include('partials/footer') %>
