<%- include('partials/header') %>

<main>
  <h1><%= title %></h1>
  <p style="color:var(--muted);margin-bottom:36px;">Browse volunteer opportunities by cause area.</p>

  <ul class="cat-grid">
    <% categories.forEach(category => { %>
      <li>
        <a href="/category/<%= category.category_id %>" class="cat-card">
          <span><%= category.name %></span>
          <span style="color:var(--muted);font-size:.8rem;">&rarr;</span>
        </a>
      </li>
    <% }); %>
  </ul>
</main>

<%- include('partials/footer') %>
