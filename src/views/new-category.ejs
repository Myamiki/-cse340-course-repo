<%- include('partials/header') %>

<main>
  <a href="/categories" class="back-link">&larr; Back to Categories</a>

  <div class="form-card">
    <div class="form-card-header">
      <h1>Create New Category</h1>
      <p>Add a new cause area for organizing projects.</p>
    </div>
    <div class="form-card-body">

      <form action="/new-category" method="POST">

        <div class="form-group">
          <label for="name">Category Name</label>
          <input type="text" id="name" name="name" maxlength="100" required placeholder="e.g. Environment, Education, Housing…">
        </div>

        <div class="form-actions">
          <button type="submit">Create Category</button>
          <a href="/categories" class="btn btn-ghost">Cancel</a>
        </div>

      </form>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
