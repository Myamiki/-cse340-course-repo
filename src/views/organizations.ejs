<%- include('partials/header') %>

<main>
  <div class="section-header" style="margin-bottom:8px;">
    <h1 style="margin:0;"><%= title %></h1>
    <% if (user && user.role_name === 'admin') { %>
      <a href="/new-organization" class="btn btn-sm btn-accent">+ Add Organization</a>
    <% } %>
  </div>
  <p style="color:var(--muted);margin-bottom:36px;">Our partner organizations making a difference in communities everywhere.</p>

  <ul class="card-grid" style="list-style:none;padding:0;margin:0;">
    <% organizations.forEach(org => { %>
      <li>
        <a href="/organization/<%= org.organization_id %>" class="org-card">
          <img class="org-logo" src="/images/<%= org.logo_filename %>" alt="<%= org.name %> logo">
          <div>
            <div class="org-name"><%= org.name %></div>
            <div class="org-email">&#9993; <%= org.contact_email %></div>
          </div>
        </a>
      </li>
    <% }); %>
  </ul>
</main>

<%- include('partials/footer') %>
