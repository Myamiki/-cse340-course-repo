<%- include('partials/header') %>

<main>
  <a href="/organization/<%= organizationDetails.organization_id %>" class="back-link">&larr; Back to Organization</a>

  <div class="form-card">
    <div class="form-card-header">
      <h1><%= title %></h1>
      <p>Update the details for this organization.</p>
    </div>
    <div class="form-card-body">

      <form action="/edit-organization/<%= organizationDetails.organization_id %>" method="POST">

        <div class="form-group">
          <label for="name">Organization Name</label>
          <input type="text" id="name" name="name" value="<%= organizationDetails.name %>" maxlength="150" required>
        </div>

        <div class="form-group">
          <label for="description">Description</label>
          <textarea id="description" name="description" maxlength="500" required><%= organizationDetails.description %></textarea>
        </div>

        <div class="form-group">
          <label for="contactEmail">Contact Email</label>
          <input type="email" id="contactEmail" name="contactEmail" value="<%= organizationDetails.contact_email %>" required>
        </div>

        <div class="form-group">
          <label for="logoFilename">Logo Filename</label>
          <input type="text" id="logoFilename" name="logoFilename" value="<%= organizationDetails.logo_filename %>" required placeholder="e.g. my-org-logo.png">
        </div>

        <div class="form-actions">
          <button type="submit">Save Changes</button>
          <a href="/organization/<%= organizationDetails.organization_id %>" class="btn btn-ghost">Cancel</a>
        </div>

      </form>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
