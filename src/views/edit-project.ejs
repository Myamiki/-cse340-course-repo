<%- include('partials/header') %>

<main>
    <h1>Edit Project</h1>

    <form action="/edit-project/<%= project.project_id %>" method="POST">

        <!-- Title -->
        <div class="form-group">
            <label for="title">Title</label>
            <input type="text" id="title" name="title" value="<%= project.title %>" maxlength="200" required />
        </div>

        <!-- Description -->
        <div class="form-group">
            <label for="description">Description</label>
            <textarea id="description" name="description" maxlength="1000" required><%= project.description %></textarea>
        </div>

        <!-- Location -->
        <div class="form-group">
            <label for="location">Location</label>
            <input type="text" id="location" name="location" value="<%= project.location %>" maxlength="200" required />
        </div>

        <!-- Date -->
        <div class="form-group">
            <label for="date">Date</label>
            <input
                type="date"
                id="date"
                name="date"
                value="<%= (project.project_date instanceof Date ? project.project_date : new Date(project.project_date)).toISOString().split('T')[0] %>"
                required
            />
        </div>

        <!-- Organization Dropdown -->
        <div class="form-group">
            <label for="organizationId">Organization</label>
            <select id="organizationId" name="organizationId" required>
                <% organizations.forEach(org => { %>
                    <option value="<%= org.organization_id %>"
                        <%= org.organization_id === project.organization_id ? 'selected' : '' %>>
                        <%= org.name %>
                    </option>
                <% }) %>
            </select>
        </div>

        <button type="submit">Update Project</button>
        <a href="/project/<%= project.project_id %>">Cancel</a>

    </form>
</main>

<%- include('partials/footer') %>
