<%- include('partials/header') %>

<main>
  <a href="/project/<%= project.project_id %>" class="back-link">&larr; Back to Project</a>

  <div class="form-card" style="max-width:680px;">
    <div class="form-card-header">
      <h1>Edit Project</h1>
      <p>Update the details for this service project.</p>
    </div>
    <div class="form-card-body">

      <form action="/edit-project/<%= project.project_id %>" method="POST">

        <div class="form-group">
          <label for="title">Project Title</label>
          <input type="text" id="title" name="title" value="<%= project.title %>" maxlength="200" required>
        </div>

        <div class="form-group">
          <label for="description">Description</label>
          <textarea id="description" name="description" maxlength="1000" required><%= project.description %></textarea>
        </div>

        <div class="form-group">
          <label for="location">Location</label>
          <input type="text" id="location" name="location" value="<%= project.location %>" maxlength="200" required>
        </div>

        <div class="form-group">
          <label for="date">Project Date</label>
          <input type="date" id="date" name="date" value="<%= (project.project_date instanceof Date ? project.project_date : new Date(project.project_date)).toISOString().split('T')[0] %>" required>
        </div>

        <div class="form-group">
          <label for="organizationId">Organization</label>
          <select id="organizationId" name="organizationId" required>
            <% organizations.forEach(org => { %>
              <option value="<%= org.organization_id %>" <%= org.organization_id === project.organization_id ? 'selected' : '' %>>
                <%= org.name %>
              </option>
            <% }); %>
          </select>
        </div>

        <div class="form-actions">
          <button type="submit">Save Changes</button>
          <a href="/project/<%= project.project_id %>" class="btn btn-ghost">Cancel</a>
        </div>

      </form>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
