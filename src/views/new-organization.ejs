<%- include('partials/header') %>

<main>
  <a href="/organizations" class="back-link">&larr; Back to Organizations</a>

  <div class="form-card">
    <div class="form-card-header">
      <h1><%= title %></h1>
      <p>Add a new partner organization to the network.</p>
    </div>
    <div class="form-card-body">

      <form action="/new-organization" method="POST">

        <div class="form-group">
          <label for="name">Organization Name</label>
          <input type="text" id="name" name="name" required placeholder="e.g. Green Portland Alliance">
        </div>

        <div class="form-group">
          <label for="description">Description</label>
          <textarea id="description" name="description" required placeholder="Brief description of the organization's mission…"></textarea>
        </div>

        <div class="form-group">
          <label for="contactEmail">Contact Email</label>
          <input type="email" id="contactEmail" name="contactEmail" required placeholder="contact@organization.org">
        </div>

        <div class="form-actions">
          <button type="submit">Create Organization</button>
          <a href="/organizations" class="btn btn-ghost">Cancel</a>
        </div>

      </form>
    </div>
  </div>
</main>

<%- include('partials/footer') %>